<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>生產管理回推系統 Pro</title>
    <style>
        :root { --primary: #1a73e8; --danger: #d93025; --bg: #f8f9fa; }
        body { font-family: sans-serif; background: var(--bg); padding: 15px; margin: 0; }
        .container { max-width: 500px; margin: auto; background: white; padding: 20px; border-radius: 15px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); }
        h2 { text-align: center; color: var(--primary); margin-bottom: 20px; }
        .summary { background: #e8f0fe; padding: 15px; border-radius: 10px; margin-bottom: 20px; border: 1px solid #d2e3fc; }
        .card { background: #fff; border: 1px solid #eee; border-radius: 10px; padding: 15px; margin-bottom: 15px; position: relative; border-left: 5px solid var(--primary); }
        label { display: block; font-size: 13px; color: #666; margin-bottom: 5px; }
        input, select { width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 8px; font-size: 16px; box-sizing: border-box; }
        .row { display: flex; gap: 10px; margin-top: 10px; align-items: center; }
        .col { flex: 1; }
        .date-display { font-size: 18px; color: var(--danger); font-weight: bold; }
        .btn-add { background: var(--primary); color: white; border: none; width: 100%; padding: 15px; border-radius: 8px; font-size: 16px; font-weight: bold; margin-top: 10px; }
        .btn-del { background: #f1f3f4; color: #5f6368; border: none; padding: 5px 10px; border-radius: 5px; position: absolute; top: 10px; right: 10px; cursor: pointer; }
    </style>
</head>
<body>

<div class="container">
    <h2>🗓️ 製程交期回推</h2>
    
    <div class="summary">
        <label>🏁 最後工單交期 (客戶要求日)</label>
        <input type="date" id="finalDeadline" onchange="calculateAll()">
    </div>

    <div id="processList">
        </div>

    <button class="btn-add" onclick="addProcessCard()">＋ 新增製程步驟</button>
</div>

<script>
    /** * 【在這裡設定你的標準製程與預設天數】
     * 你可以隨時增加或修改這份清單
     */
    const processTemplate = [
        { name: "雷射沖孔", days: 3 },
        { name: "折彎", days: 3 },
        { name: "抽孔", days: 4 },
        { name: "攻牙", days: 2 },
        { name: "鉚釘", days: 1 },
        { name: "點焊", days: 1 },
         { name: "燒焊", days: 7 },
        { name: "研磨", days: 3 },
        { name: "髮線", days: 4 },
        { name: "銑床", days: 2 },
        { name: "烤漆", days: 1 },
        { name: "電鍍鎳", days: 1 },
         { name: "電鍍五彩", days: 7 },
        { name: "電鍍白鋅", days: 3 },
        { name: "陽極", days: 4 },
        { name: "貼防烤", days: 2 },
        { name: "印刷", days: 1 },
        { name: "噴砂", days: 1 },
         { name: "電解拋光", days: 7 },
        { name: "鈍化", days: 3 },
        { name: "震動研磨", days: 4 },
        { name: "組立(鎖固)", days: 2 },
        { name: "拋光", days: 1 },
        { name: "沖壓便模", days: 1 },
        { name: "雷射補割", days: 4 },
        { name: "滑孔", days: 2 },
        { name: "補鑽孔", days: 1 },
        { name: "段差", days: 1 },
         { name: "二次折彎", days: 7 },
        { name: "二次鉚釘", days: 3 },
        { name: "拉釘", days: 4 },
        { name: "植釘", days: 2 },
        { name: "裁切", days: 1 },
        { name: "外發雷雕", days: 7 },
        { name: "電鍍黑", days: 3 },
        { name: "NCT夾沖", days: 4 },
        { name: "塗銀漆", days: 2 },
        { name: "皮膜處裡", days: 1 },
        { name: "組裝(拉釘)", days: 1 },
         { name: "酪酸鹽", days: 7 },
        { name: "蝕刻", days: 3 },
        { name: "品檢", days: 4 },
        { name: "外發", days: 2 },
        { name: "外購", days: 1 },
        { name: "包裝", days: 1 }
    ];

    function addProcessCard() {
        const list = document.getElementById('processList');
        const div = document.createElement('div');
        div.className = 'card';
        
        // 生成選項
        let options = processTemplate.map((p, index) => 
            `<option value="${index}">${p.name} (預設 ${p.days} 天)</option>`
        ).join('');
        
        div.innerHTML = `
            <button class="btn-del" onclick="this.parentElement.remove(); calculateAll();">✕</button>
            <label>選擇製程項目</label>
            <select class="p-select" onchange="handleSelectChange(this)">
                <option value="">-- 請選擇製程 --</option>
                ${options}
                <option value="custom">自定義名稱...</option>
            </select>
            <input type="text" class="custom-name" placeholder="請輸入製程名稱" style="display:none; margin-top:8px;" oninput="calculateAll()">
            
            <div class="row">
                <div class="col">
                    <label>調整天數</label>
                    <input type="number" class="p-days" value="0" min="0" oninput="calculateAll()">
                </div>
                <div class="col">
                    <label>應完成日期</label>
                    <div class="date-display">--</div>
                </div>
            </div>
        `;
        list.appendChild(div);
    }

    // 當選單改變時，自動填入該製程的預設天數
    function handleSelectChange(selectElem) {
        const card = selectElem.parentElement;
        const customInput = card.querySelector('.custom-name');
        const daysInput = card.querySelector('.p-days');
        
        if (selectElem.value === "custom") {
            customInput.style.display = "block";
            daysInput.value = 1; // 自定義預設 1 天
        } else if (selectElem.value !== "") {
            customInput.style.display = "none";
            // 抓取範本裡的預設天數
            const templateIndex = selectElem.value;
            daysInput.value = processTemplate[templateIndex].days;
        }
        
        calculateAll();
    }

    function calculateAll() {
        const finalDateVal = document.getElementById('finalDeadline').value;
        if (!finalDateVal) return;

        let currentDate = new Date(finalDateVal);
        const cards = document.querySelectorAll('.card');

        // 由上往下回推計算
        cards.forEach(card => {
            const days = parseInt(card.querySelector('.p-days').value) || 0;
            const display = card.querySelector('.date-display');
            
            currentDate.setDate(currentDate.getDate() - days);
            
            const y = currentDate.getFullYear();
            const m = String(currentDate.getMonth() + 1).padStart(2, '0');
            const d = String(currentDate.getDate()).padStart(2, '0');
            display.innerText = `${y}/${m}/${d}`;
        });
    }

    // 初始化
    window.onload = function() {
        document.getElementById('finalDeadline').valueAsDate = new Date();
    };
</script>

</body>
</html>
